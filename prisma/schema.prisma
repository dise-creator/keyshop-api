generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Platform {
  id        String    @id @default(uuid())
  slug      String    @unique
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  products  Product[]
}

model Region {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  flag      String
  currency  String
  products  Product[]
}

model Product {
  id         String    @id @default(uuid())
  platformId String
  regionId   String
  amount     Float
  isPopular  Boolean   @default(false)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  platform   Platform  @relation(fields: [platformId], references: [id])
  region     Region    @relation(fields: [regionId], references: [id])
  orders     Order[]
  keys       Key[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id        String   @id @default(uuid())
  userId    String
  productId String
  amountRub Float
  rate      Float
  markup    Float
  status    String   @default("pending")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  keys      Key[]
}

model Currency {
  id        String   @id @default(uuid())
  code      String   @unique
  rate      Float
  markup    Float    @default(0.10)
  updatedAt DateTime @updatedAt
}

model Key {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  code          String
  isUsed        Boolean  @default(false)
  usedInOrderId String?
  order         Order?   @relation(fields: [usedInOrderId], references: [id])
  createdAt     DateTime @default(now())
}